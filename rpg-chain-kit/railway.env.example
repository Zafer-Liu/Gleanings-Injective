# Copy these values into Railway → Service → Variables. Do not commit real secrets.
EVM_RPC_URL=https://k8s.testnet.json-rpc.injective.network/
RPG_ITEM_CONTRACT_ADDRESS=0xc8167b100bc7Ad611299d634D09b853C6310619e
CHAIN_ID=1439
CHAIN_NAME=Injective EVM Testnet
NATIVE_CURRENCY=INJ
BLOCK_EXPLORER=https://testnet.blockscout.injective.network/

# Railway creates this automatically after Networking → Generate Domain.
# In Railway's variable editor set it to: https://${{RAILWAY_PUBLIC_DOMAIN}}
PUBLIC_SHARE_ORIGIN=https://your-service.up.railway.app

# Add the deployed game frontend URL here. Keep the local URLs for development.
CORS_ORIGINS=https://your-game.up.railway.app,http://127.0.0.1:5173,http://localhost:5173

# Create a public project at https://dashboard.walletconnect.com/ and allow this Railway domain.
# This is not a wallet private key.
WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
