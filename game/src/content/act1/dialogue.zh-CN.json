{
  "groups": {
    "opening": [
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "凌晨一点，窗外的城市仍亮着。"
      },
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "太婆寄来的最后一箱东西……我拖了三个月还没整理。"
      }
    ],
    "box": [
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "旧衣服、药袋，还有……一张字条。"
      }
    ],
    "note": [
      {
        "speakerId": "taipo_note",
        "speakerName": "太婆的字条",
        "text": "念安，等你想家了，就开。——太婆"
      },
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "她知道我一定会把它带到这里。"
      }
    ],
    "mia": [
      {
        "speakerId": "actor_mia",
        "speakerName": "米娅",
        "text": "你还没睡？"
      },
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "在整理太婆留下的东西。"
      },
      {
        "speakerId": "actor_mia",
        "speakerName": "米娅",
        "text": "就是那坛一直没开的酒？"
      },
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "嗯。她让我“等想家了再开”。"
      },
      {
        "speakerId": "actor_mia",
        "speakerName": "米娅",
        "text": "那你现在想家吗？"
      },
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "……我不知道。"
      }
    ],
    "jarEarly": [
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "像是在等我想起什么。"
      }
    ],
    "jarReady": [
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "红布、封泥和冰凉的陶壁，在夜里安静得过分。"
      }
    ],
    "transition": [
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "太婆，我开了。"
      },
      {
        "speakerId": "actor_mia",
        "speakerName": "米娅",
        "text": "念安……你看见了吗？"
      },
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "酒香没有散开。它像一条路，把你拉进一场很久以前的冬天。"
      }
    ],
    "inspectDesk": [
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "英文账单压着三通未接来电。国内那边，已经是早晨了。"
      }
    ],
    "inspectWindow": [
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "这里的夜从不真正变黑，家乡的清晨却已经开始。"
      }
    ],
    "inspectPhoto": [
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "照片里的太婆还很年轻，手指却已经被红曲染红。"
      }
    ],
    "inspectTakeout": [
      {
        "speakerId": "actor_yi",
        "speakerName": "林念安",
        "text": "凉掉的外卖。又忘了吃晚饭。"
      }
    ],
    "inspectPhone": [
      {
        "speakerId": "actor_yi",
